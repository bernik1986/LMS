# Copy this file to .env on the production server and fill real values.

NODE_ENV="production"
LMS_STORAGE="prisma"

# PostgreSQL connection for the production database.
DATABASE_URL="postgresql://marine_lms_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/marine_lms?schema=public"

# The app normally listens on localhost behind Nginx/Apache/IIS.
HOST="127.0.0.1"
PORT="3000"

# Public HTTPS URL used in certificate QR codes and notification links.
PUBLIC_BASE_URL="https://example.com"
APP_URL="https://example.com"

# Trust X-Forwarded-* only when the app is bound to localhost behind your own reverse proxy.
TRUST_PROXY="true"
LMS_ALLOW_DEMO_DATA="false"
SESSION_TTL_HOURS="12"
PASSWORD_RESET_TTL_MINUTES="30"

# Upload limits.
MAX_MATERIAL_UPLOAD_MB="25"
MAX_VIDEO_UPLOAD_MB="512"
MAX_PHOTO_UPLOAD_MB="3"
MAX_COURSE_IMAGE_MB="8"
MAX_CERTIFICATE_TEMPLATE_MB="20"
# This is a hard request limit. Keep it only slightly above the largest permitted upload.
MAX_REQUEST_BODY_MB="520"

# Optional SMTP delivery for notification queue.
# If empty, notifications stay in the admin log.
SMTP_HOST="mail.maritimelearning.store"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_STARTTLS="false"
SMTP_USER="info@maritimelearning.store"
SMTP_PASS="CHANGE_ME_MAIL_PASSWORD"
SMTP_FROM="info@maritimelearning.store"
SMTP_TLS_REJECT_UNAUTHORIZED="true"

# Only used if you run seed scripts. Do not leave example password on production.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="CHANGE_ME_STRONG_ADMIN_PASSWORD"
