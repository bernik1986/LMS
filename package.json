{
  "name": "custom-lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/lms-server.mjs",
    "start": "node scripts/lms-server.mjs",
    "preview": "node scripts/lms-server.mjs",
    "scaffold:dev": "next dev",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "build": "npm run typecheck && npm run lint",
    "typecheck": "tsc --noEmit",
    "reset:data": "node scripts/reset-data.mjs",
    "backup:data": "node scripts/backup-data.mjs",
    "import:wp:dry-run": "node scripts/import-wordpress-tutor.mjs --dry-run",
    "import:wp:apply": "node scripts/import-wordpress-tutor.mjs --apply",
    "smoke": "node scripts/smoke-test.mjs",
    "test": "node scripts/regression-test.mjs",
    "test:regression": "node scripts/regression-test.mjs",
    "audit:prod": "npm audit --omit=dev",
    "lint": "eslint .",
    "prod:check": "node scripts/prod-check.mjs",
    "prod:check:strict": "node scripts/prod-check.mjs --strict",
    "prod:check:no-uploads": "node scripts/prod-check.mjs --skip-uploads",
    "prod:backup": "node scripts/backup-production.mjs",
    "prod:backup:db": "node scripts/backup-production.mjs --skip-uploads",
    "prod:repair-uploads": "node scripts/repair-upload-paths.mjs",
    "prod:repair-uploads:apply": "node scripts/repair-upload-paths.mjs --apply",
    "prod:start": "node scripts/prod-start.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:migrate:schema": "node scripts/apply-prisma-migrations.mjs",
    "db:migrate:json:dry-run": "node scripts/migrate-json-to-prisma.mjs",
    "db:migrate:json:apply": "node scripts/migrate-json-to-prisma.mjs --apply",
    "db:migrate:json:force-replace": "node scripts/migrate-json-to-prisma.mjs --apply --force-replace",
    "db:verify": "node scripts/verify-prisma-db.mjs",
    "db:verify:migration": "node scripts/verify-prisma-migration.mjs",
    "db:doctor": "node scripts/db-doctor.mjs",
    "db:setup": "npm run prod:migrate",
    "db:first-import": "npm run db:migrate:schema && npm run db:migrate:json:apply && npm run db:verify",
    "prod:migrate": "npm run db:migrate:schema && npm run db:verify",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
